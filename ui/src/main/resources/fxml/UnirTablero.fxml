<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox minHeight="-Infinity" minWidth="-Infinity" prefHeight="250.0" prefWidth="400.0" spacing="16.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tasku.ui.presentation.controllers.UnirTableroController">
    
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label styleClass="label-title" text="Unirme a un tablero" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <VBox spacing="6.0">
            <children>
                <Label styleClass="label-section" text="URL DEL TABLERO" />
                <TextField fx:id="txtUrl" promptText="tasku://tablero/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" styleClass="join-input" />
                <Label styleClass="label-helper" text="Pega el enlace completo (tasku://tablero/...) que te compartió el administrador." />
                <Label fx:id="lblMensajeError" styleClass="label-helper" text="" />
            </children>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
            <Button onAction="#handleCancel" styleClass="toggle-card-type" text="Cancelar">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </Button>
                <Button mnemonicParsing="false" onAction="#handleUnirse" styleClass="btn-primary" text="Unirme" />
            </children>
            <VBox.margin>
                <Insets top="8.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>
