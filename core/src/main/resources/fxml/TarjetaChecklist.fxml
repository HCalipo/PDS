<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="cardContainer" maxWidth="300.0" spacing="4.0" styleClass="card-modern" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tasku.core.ui.controllers.TarjetaChecklistController">
    <padding>
        <Insets bottom="12.0" left="14.0" right="14.0" top="12.0" />
    </padding>

    <!-- Primera línea: Etiqueta + Botón opciones -->
    <HBox alignment="CENTER_LEFT">
        <!-- Etiqueta (chip de color con nombre) -->
        <HBox fx:id="hboxEtiqueta" visible="false">
            <Label fx:id="lblEtiqueta" styleClass="card-label-chip" text="Etiqueta" />
        </HBox>
        
        <Region HBox.hgrow="ALWAYS" />
        
        <Button fx:id="btnOpciones" styleClass="card-menu" text="⋮" />
    </HBox>

    <!-- Segunda línea: Título -->
    <Label fx:id="lblTitulo" maxWidth="1.7976931348623157E308" styleClass="card-title-modern" text="Título del checklist" textOverrun="CLIP" wrapText="true" />

    <!-- Barra de progreso -->
    <HBox spacing="8.0">
        <Label fx:id="lblProgreso" styleClass="checklist-progress" text="0/0" />
    </HBox>

    <!-- Lista de items -->
    <VBox fx:id="vboxChecklist" spacing="2.0" styleClass="checklist-items">
        <CheckBox mnemonicParsing="false" text="Item 1" />
    </VBox>

    <!-- Fecha -->
    <Label fx:id="lblFecha" styleClass="card-date" text="Fecha" />
</VBox>
