<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox minHeight="-Infinity" minWidth="-Infinity" prefHeight="420.0" prefWidth="600.0" spacing="20.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tasku.ui.presentation.controllers.AñadirTableroController">
    <padding>
        <Insets bottom="24.0" left="28.0" right="28.0" top="24.0" />
    </padding>

    <Label styleClass="label-title" text="Crear nuevo tablero" />

    <VBox spacing="12.0">
        <Label styleClass="label-section" text="SELECCIONA UNA PLANTILLA" />

        <HBox alignment="CENTER" spacing="16.0">

            <VBox fx:id="templateBlank" alignment="CENTER" onMouseClicked="#onTemplateSelected" spacing="8.0" styleClass="template-selector-card, template-selector-active">
                <HBox alignment="CENTER_LEFT" prefHeight="90.0" prefWidth="168.0" spacing="6.0" style="-fx-background-color: #dcfce7; -fx-background-radius: 6; -fx-padding: 8;">
                    <VBox spacing="4.0" style="-fx-background-color: rgba(255,255,255,0.9); -fx-background-radius: 4; -fx-padding: 5 4 5 4;" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 8px; -fx-font-weight: bold; -fx-text-fill: #166534;" text="General" />
                        <Region maxWidth="Infinity" prefHeight="7.0" style="-fx-background-color: #bbf7d0; -fx-background-radius: 2;" />
                        <Region maxWidth="Infinity" prefHeight="7.0" style="-fx-background-color: #bbf7d0; -fx-background-radius: 2;" />
                        <Region maxWidth="Infinity" prefHeight="7.0" style="-fx-background-color: #bbf7d0; -fx-background-radius: 2;" />
                    </VBox>
                </HBox>
                <Label styleClass="template-label" text="En blanco" />
                <Label style="-fx-font-size: 10px; -fx-text-fill: #64748b;" text="1 lista · General" />
            </VBox>

            <VBox fx:id="template1" alignment="CENTER" onMouseClicked="#onTemplateSelected" spacing="8.0" styleClass="template-selector-card">
                <HBox alignment="CENTER_LEFT" prefHeight="90.0" prefWidth="168.0" spacing="4.0" style="-fx-background-color: #dbeafe; -fx-background-radius: 6; -fx-padding: 8;">
                    <VBox spacing="3.0" style="-fx-background-color: rgba(255,255,255,0.9); -fx-background-radius: 4; -fx-padding: 4 3 4 3;" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 7px; -fx-font-weight: bold; -fx-text-fill: #1e40af;" text="Pendientes" />
                        <Region maxWidth="Infinity" prefHeight="6.0" style="-fx-background-color: #bfdbfe; -fx-background-radius: 2;" />
                        <Region maxWidth="Infinity" prefHeight="6.0" style="-fx-background-color: #bfdbfe; -fx-background-radius: 2;" />
                        <Region maxWidth="Infinity" prefHeight="6.0" style="-fx-background-color: #bfdbfe; -fx-background-radius: 2;" />
                    </VBox>
                    <VBox spacing="3.0" style="-fx-background-color: rgba(255,255,255,0.9); -fx-background-radius: 4; -fx-padding: 4 3 4 3;" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 7px; -fx-font-weight: bold; -fx-text-fill: #1e40af;" text="En progreso" />
                        <Region maxWidth="Infinity" prefHeight="6.0" style="-fx-background-color: #bfdbfe; -fx-background-radius: 2;" />
                        <Region maxWidth="Infinity" prefHeight="6.0" style="-fx-background-color: #bfdbfe; -fx-background-radius: 2;" />
                    </VBox>
                    <VBox spacing="3.0" style="-fx-background-color: rgba(255,255,255,0.9); -fx-background-radius: 4; -fx-padding: 4 3 4 3;" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 7px; -fx-font-weight: bold; -fx-text-fill: #991b1b;" text="Bloqueado" />
                        <Region maxWidth="Infinity" prefHeight="6.0" style="-fx-background-color: #fecaca; -fx-background-radius: 2;" />
                        <Region maxWidth="Infinity" prefHeight="6.0" style="-fx-background-color: #fecaca; -fx-background-radius: 2;" />
                    </VBox>
                </HBox>
                <Label styleClass="template-label" text="Kanban" />
                <Label style="-fx-font-size: 10px; -fx-text-fill: #64748b;" text="3 listas · Pendientes › En progreso › Bloqueado" />
            </VBox>

            <VBox fx:id="template2" alignment="CENTER" onMouseClicked="#onTemplateSelected" spacing="8.0" styleClass="template-selector-card">
                <HBox alignment="CENTER_LEFT" prefHeight="90.0" prefWidth="168.0" spacing="4.0" style="-fx-background-color: #ffedd5; -fx-background-radius: 6; -fx-padding: 8;">
                    <VBox spacing="3.0" style="-fx-background-color: rgba(255,255,255,0.9); -fx-background-radius: 4; -fx-padding: 4 3 4 3;" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 7px; -fx-font-weight: bold; -fx-text-fill: #713f12;" text="Backlog" />
                        <Region maxWidth="Infinity" prefHeight="6.0" style="-fx-background-color: #fef08a; -fx-background-radius: 2;" />
                        <Region maxWidth="Infinity" prefHeight="6.0" style="-fx-background-color: #fef08a; -fx-background-radius: 2;" />
                        <Region maxWidth="Infinity" prefHeight="6.0" style="-fx-background-color: #fef08a; -fx-background-radius: 2;" />
                    </VBox>
                    <VBox spacing="3.0" style="-fx-background-color: rgba(255,255,255,0.9); -fx-background-radius: 4; -fx-padding: 4 3 4 3;" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 7px; -fx-font-weight: bold; -fx-text-fill: #9a3412;" text="Sprint" />
                        <Region maxWidth="Infinity" prefHeight="6.0" style="-fx-background-color: #fed7aa; -fx-background-radius: 2;" />
                        <Region maxWidth="Infinity" prefHeight="6.0" style="-fx-background-color: #fed7aa; -fx-background-radius: 2;" />
                    </VBox>
                    <VBox spacing="3.0" style="-fx-background-color: rgba(255,255,255,0.9); -fx-background-radius: 4; -fx-padding: 4 3 4 3;" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 7px; -fx-font-weight: bold; -fx-text-fill: #1e40af;" text="QA" />
                        <Region maxWidth="Infinity" prefHeight="6.0" style="-fx-background-color: #bfdbfe; -fx-background-radius: 2;" />
                        <Region maxWidth="Infinity" prefHeight="6.0" style="-fx-background-color: #bfdbfe; -fx-background-radius: 2;" />
                    </VBox>
                </HBox>
                <Label styleClass="template-label" text="Scrum" />
                <Label style="-fx-font-size: 10px; -fx-text-fill: #64748b;" text="3 listas · Backlog › Sprint › QA" />
            </VBox>

        </HBox>
        <VBox.margin>
            <Insets top="4.0" />
        </VBox.margin>
    </VBox>

    <VBox spacing="8.0">
        <Label styleClass="label-section" text="NOMBRE DEL TABLERO" />
        <TextField fx:id="boardNameField" prefHeight="40.0" promptText="Ej. Proyecto Alpha" styleClass="join-input" />
        <VBox.margin>
            <Insets top="4.0" />
        </VBox.margin>
    </VBox>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Label fx:id="lblBoardResult" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
        <Button onAction="#handleCancel" styleClass="toggle-card-type" text="Cancelar" />
        <Button mnemonicParsing="false" onAction="#handleCreateBoard" styleClass="btn-primary" text="Crear tablero" />
        <VBox.margin>
            <Insets top="8.0" />
        </VBox.margin>
    </HBox>

</VBox>
