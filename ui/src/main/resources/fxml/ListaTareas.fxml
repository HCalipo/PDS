<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="listaTareas" maxWidth="Infinity" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tasku.ui.presentation.controllers.ListaTareasController">
   <children>
      <HBox fx:id="columnHeader" alignment="CENTER_LEFT" styleClass="column-header">
         <children>
            <Label fx:id="columnTitle" styleClass="column-title, text-done" text="NOMBRE" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="taskCounter" styleClass="task-counter" text="0" />
            <Button fx:id="btnRenameList" mnemonicParsing="false" onAction="#handleRenameList" styleClass="btn-list-action" text="✏" />
            <Button fx:id="btnDeleteList" mnemonicParsing="false" onAction="#handleDeleteList" styleClass="btn-list-action" text="🗑" />
         </children>
      </HBox>
      <VBox fx:id="tasksContainer" styleClass="task-list" VBox.vgrow="ALWAYS">
         <children>
            <VBox fx:id="emptyState">
               <children>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleCrearTarea" text="Pulsa aquí para crear una nueva tarea &#10;O &#10;Arrastra para moverla" textAlignment="CENTER">
                     <styleClass>
                        <String fx:value="empty-state" />
                        <String fx:value="empty-subtitle" />
                     </styleClass>
                  </Button>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
   <styleClass>
      <String fx:value="column" />
      <String fx:value="col-todo" />
   </styleClass>
</VBox>
