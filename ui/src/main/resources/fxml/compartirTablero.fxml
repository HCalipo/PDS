<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox minHeight="-Infinity" minWidth="-Infinity" prefHeight="470.0" prefWidth="600.0" spacing="16.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tasku.ui.presentation.controllers.CompartirTableroController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label styleClass="label-title" text="Compartir tablero" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <VBox spacing="8.0">
            <children>
                <Label styleClass="label-section" text="COMPARTIR CON UN USUARIO" />
                <TextField fx:id="txtEmail" promptText="correo@ejemplo.com" styleClass="join-input" />
                <HBox spacing="10.0">
                    <children>
                        <ToggleButton fx:id="toggleLectura" selected="true" styleClass="toggle-card-type" text="Solo lectura">
                            <toggleGroup>
                                <ToggleGroup fx:id="permisosGroup" />
                            </toggleGroup>
                        </ToggleButton>
                        <ToggleButton fx:id="toggleEditar" styleClass="toggle-card-type" text="Puede editar" toggleGroup="$permisosGroup" />
                        <ToggleButton fx:id="toggleAdministrador" styleClass="toggle-card-type" text="Administrador" toggleGroup="$permisosGroup" />
                    </children>
                </HBox>
                <Label styleClass="label-helper" text="Solo lectura: solo ver. Puede editar: crear y modificar tarjetas. Administrador: control total." />
                <Button fx:id="btnCompartir" maxWidth="1.7976931348623157E308" onAction="#handleCompartir" styleClass="btn-primary" text="Compartir" />
                <Label fx:id="lblEstado" styleClass="label-helper" text="" />
            </children>
        </VBox>

        <Region prefHeight="1.0" style="-fx-background-color: #e2e8f0;" />

        <VBox spacing="8.0">
            <children>
                <Label styleClass="label-section" text="ENLACE DE ACCESO AL TABLERO" />
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <TextField fx:id="txtEnlace" editable="false" promptText="URL del tablero" styleClass="join-input" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnCopiar" onAction="#handleCopiar" styleClass="btn-add-small" text="Copiar" />
                    </children>
                </HBox>
                <Label styleClass="label-helper" text="El destinatario puede usar este enlace en 'Unirse a tablero' si todavía no tiene acceso." />
            </children>
        </VBox>

        <HBox alignment="CENTER_RIGHT">
            <children>
                <Button onAction="#handleCancelar" styleClass="toggle-card-type" text="Cerrar" />
            </children>
        </HBox>
    </children>
</VBox>
