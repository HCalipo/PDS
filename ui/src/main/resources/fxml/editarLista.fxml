<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox minHeight="-Infinity" minWidth="-Infinity" prefHeight="253.0" prefWidth="600.0" spacing="16.0" styleClass="template-card" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tasku.ui.presentation.controllers.EditarListaController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12.0">
        <Label styleClass="label-title" text="Editar Lista" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnCerrar" onAction="#handleCerrar" styleClass="btn-close" text="✕" />
    </HBox>

    <Label styleClass="label-section" text="Título" />
    <TextField fx:id="txtTitulo" onAction="#handleGuardar" styleClass="join-input" />

    <HBox spacing="8.0" />

    <Region prefHeight="10.0" />

    <HBox alignment="CENTER_RIGHT" spacing="12.0">
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleGuardar" styleClass="btn-primary" text="Guardar" />
    </HBox>
</VBox>
