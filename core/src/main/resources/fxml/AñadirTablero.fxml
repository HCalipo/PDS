<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox prefWidth="600.0" spacing="20.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    
    <padding>
        <Insets bottom="24.0" left="28.0" right="28.0" top="24.0" />
    </padding>

    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Crear nuevo tablero" />
                <Region HBox.hgrow="ALWAYS" />
                
                <Button mnemonicParsing="false" style="-fx-padding: 4;" styleClass="icon-button">
                    <graphic>
                        <Group>
                            <children>
                                <SVGPath content="M256-200l-56-56 224-224-224-224 56-56 224 224 224-224 56 56-224 224 224 224-56 56-224-224-224 224Z" fill="#64748b" scaleX="0.025" scaleY="0.025" />
                            </children>
                        </Group>
                    </graphic>
                </Button>
            </children>
        </HBox>

        <VBox spacing="12.0">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #475569;" text="SELECCIONA UNA PLANTILLA" />
                
                <HBox alignment="CENTER" spacing="24.0">
                    <children>
                        <VBox alignment="CENTER" spacing="10.0" styleClass="template-selector-card, template-selector-active">
                            <children>
                                <Region prefHeight="110.0" prefWidth="160.0" styleClass="template-preview, preview-blank" />
                                <Label styleClass="template-label" text="En blanco" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" spacing="10.0" styleClass="template-selector-card">
                            <children>
                                <Region prefHeight="110.0" prefWidth="160.0" styleClass="template-preview, preview-kanban" />
                                <Label styleClass="template-label" text="Plantilla1" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" spacing="10.0" styleClass="template-selector-card">
                            <children>
                                <Region prefHeight="110.0" prefWidth="160.0" styleClass="template-preview, preview-scrum" />
                                <Label styleClass="template-label" text="Plantilla2" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
            <VBox.margin>
                <Insets top="4.0" />
            </VBox.margin>
        </VBox>

        <VBox spacing="8.0">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #475569;" text="NOMBRE DEL TABLERO" />
                <TextField prefHeight="40.0" promptText="Ej. Proyecto Alpha" styleClass="join-input" />
            </children>
            <VBox.margin>
                <Insets top="12.0" />
            </VBox.margin>
        </VBox>

        <HBox alignment="CENTER_RIGHT">
            <children>
                <Button mnemonicParsing="false" prefHeight="40.0" prefWidth="120.0" styleClass="btn-primary" text="Crear tablero" />
            </children>
            <VBox.margin>
                <Insets top="16.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>
