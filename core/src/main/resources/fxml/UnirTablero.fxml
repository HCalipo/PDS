<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox prefWidth="400.0" spacing="16.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Unirme a un tablero" />
                <Region HBox.hgrow="ALWAYS" />
                
                <Button mnemonicParsing="false" style="-fx-padding: 4;" styleClass="icon-button">
                    <graphic>
                        <Group>
                            <children>
                                <SVGPath content="M256-200l-56-56 224-224-224-224 56-56 224 224 224-224 56 56-224 224 224 224-56 56-224-224-224 224Z" fill="#64748b" scaleX="0.025" scaleY="0.025" />
                            </children>
                        </Group>
                    </graphic>
                </Button>
            </children>
        </HBox>

        <VBox spacing="6.0">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-text-fill: #475569;" text="URL DEL TABLERO" />
                <TextField promptText="https://tasku.app/b/codigo-del-tablero" styleClass="join-input" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;" text="Pide al administrador del tablero el enlace de invitación." />
            </children>
        </VBox>

        <HBox alignment="CENTER_RIGHT">
            <children>
                <Button mnemonicParsing="false" styleClass="btn-primary" text="Unirme" />
            </children>
            <VBox.margin>
                <Insets top="8.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>
