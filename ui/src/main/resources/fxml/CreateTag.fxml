<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox minHeight="-Infinity" minWidth="-Infinity" prefHeight="460.0" prefWidth="600.0" spacing="16.0" styleClass="template-card" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tasku.ui.presentation.controllers.CreateTagController">
    <padding>
        <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
    </padding>

    <Label styleClass="label-title" text="Crear Etiqueta" />

    <Label styleClass="label-section" text="Nombre" />
    <TextField fx:id="txtNombre" promptText="Ej. Urgente, Backend, Diseño..." styleClass="join-input" />

    <Label styleClass="label-section" text="Paleta de colores" />
    <HBox spacing="8.0">
        <ToggleButton onAction="#handleTogglePaleta" selected="true" styleClass="toggle-card-type" text="Normal">
            <toggleGroup>
                <ToggleGroup fx:id="paletaGroup" />
            </toggleGroup>
        </ToggleButton>
        <ToggleButton onAction="#handleTogglePaleta" styleClass="toggle-card-type" text="Pastel" toggleGroup="$paletaGroup" />
        <ToggleButton onAction="#handleTogglePaleta" styleClass="toggle-card-type" text="Neón" toggleGroup="$paletaGroup" />
        <ToggleButton onAction="#handleTogglePaleta" styleClass="toggle-card-type" text="Tierra" toggleGroup="$paletaGroup" />
        <ToggleButton onAction="#handleTogglePaleta" styleClass="toggle-card-type" text="Oscuro" toggleGroup="$paletaGroup" />
    </HBox>

    <Label styleClass="label-section" text="Color" />
    <GridPane fx:id="gridColores" hgap="10.0" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints />
            <ColumnConstraints />
            <ColumnConstraints />
            <ColumnConstraints />
            <ColumnConstraints />
        </columnConstraints>
    </GridPane>

    <HBox alignment="CENTER_LEFT" spacing="12.0">
        <Label styleClass="label-section" text="Preview:" />
        <Circle fx:id="colorPreview" radius="12.0" strokeWidth="2.0" />
        <Label fx:id="lblColorHex" styleClass="label-helper" text="#000000" />
    </HBox>

    <HBox alignment="CENTER_RIGHT" spacing="12.0">
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleCancel" styleClass="toggle-card-type" text="Cancelar" />
        <Button onAction="#handleCreate" styleClass="btn-primary" text="Crear" />
    </HBox>
</VBox>
