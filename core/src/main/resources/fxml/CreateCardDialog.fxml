<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="450.0" spacing="16.0" styleClass="template-card" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tasku.core.ui.controllers.CreateCardController">
    <padding>
        <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Header -->
    <Label styleClass="header-title" text="Crear Tarjeta" />

    <!-- Tipo de tarjeta -->
    <Label styleClass="template-card-desc" text="Tipo de tarjeta" />
    <HBox spacing="20.0">
        <RadioButton fx:id="radioTexto" selected="true" styleClass="nav-item" text="Texto" userData="TEXT" />
        <RadioButton fx:id="radioChecklist" styleClass="nav-item" text="Checklist" userData="CHECKLIST" />
    </HBox>

    <!-- Título -->
    <Label styleClass="template-card-desc" text="Título">
        <font>
            <Font size="12.0" />
        </font>
    </Label>
    <TextField fx:id="titleField" promptText="Introduce el título de la tarjeta" styleClass="join-input" />

    <!-- Botones -->
    <HBox alignment="CENTER_RIGHT" spacing="12.0">
        <Button onAction="#handleCancel" styleClass="icon-button" text="Cancelar" />
        <Button onAction="#handleCreate" styleClass="btn-primary" text="Crear Tarjeta" />
    </HBox>
</VBox>
